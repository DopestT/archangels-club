# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details → Pooled connection
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=change_this_to_a_strong_random_secret_minimum_32_chars
CLIENT_URL=http://localhost:3000
# Strong random string — grants admin bypass to X-Admin-Key header requests
ADMIN_KEY=change_this_to_a_strong_random_admin_key

# ── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Optional: publishable key for client if needed
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
